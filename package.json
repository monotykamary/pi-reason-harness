{
  "name": "pi-reason-harness",
  "version": "1.0.1",
  "description": "Recursive self-improving reasoning harness for pi \u2014 iterate, verify, improve. Builds task-specific reasoning strategies on top of any LLM.",
  "keywords": [
    "pi-package"
  ],
  "bin": {
    "pi-reason-harness": "harness/cli.ts"
  },
  "files": [
    "extensions",
    "harness",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "@earendil-works/pi-tui": "0.79.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@sinclair/typebox": "0.34.49"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "fast-xml-builder": "1.2.0",
    "protobufjs": "8.4.0",
    "ws": "8.20.1"
  }
}
